# Gateway runtime port
PORT=3000

# Node environment: development | production | test
NODE_ENV=development

# Base URL for the FastAPI NLP service
FASTAPI_BASE_URL=http://localhost:8000

# Per-request timeout when calling FastAPI (milliseconds)
FASTAPI_TIMEOUT_MS=5000

# Allowed CORS origin for the editor UI ("*" for local dev)
CORS_ORIGIN=*
