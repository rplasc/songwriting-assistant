      "notes": "Canonical multisyllabic English pair."
    },
    {
      "query": "running",
      "mode": "multisyllabic",
      "expected_any_of": ["sunning", "stunning", "shunning", "punning", "gunning"],
      "must_not_include": ["running"],
      "notes": "2-syllable stressed tail UH1_N_IH0_NG."
    },
    {
      "query": "swimming",
      "mode": "multisyllabic",
      "expected_any_of": ["dimming", "skimming", "trimming", "brimming"],
      "must_not_include": ["swimming"],
      "notes": "IH1_M_IH0_NG tail."
    },
    {
      "query": "morning",
      "mode": "multisyllabic",
      "expected_any_of": ["warning", "scorning", "mourning", "storming"],
      "must_not_include": ["morning"],
      "notes": "AO1_R_N_IH0_NG / closely related tails."
    },
    {
      "query": "meticulous",
      "mode": "multisyllabic",
      "expected_any_of": ["ridiculous"],
      "must_not_include": ["meticulous"],
      "notes": "Phase 5 M2: long shared tail beats short. The multisyllabic length bonus should keep ridiculous near the top."
