{
  "$schema_note": "Phase 5 M1 multisyllabic golden set. mode='multisyllabic' is strict: results require both query and candidate to share a >=2-vowel stressed tail. Many dactylic queries return 0 results, which is honest. We seed cases known to have at least one corpus match.",
  "limit": 10,
  "cases": [
