# Base URL of the NestJS gateway. Defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# WebSocket URL for the Socket.IO gateway. Defaults to NEXT_PUBLIC_API_BASE_URL if unset.
# Override only when the WS host differs from the HTTP host.
# NEXT_PUBLIC_WS_URL=http://localhost:3000
